# Elastic Cloud Serverless connection
ES_HOST=https://your-deployment.es.region.cloud.es.io
ES_API_KEY=your-api-key-here

# Optional: Inference endpoint ID for semantic_text fields
# If not set, semantic_text fields will be downgraded to text
ES_INFERENCE_ID=

# Kibana (Agent Builder)
KIBANA_URL=https://your-project.kb.region.cloud.es.io
KIBANA_API_KEY=your-kibana-api-key

# OpenRouter (backup agent)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
